# DockBack configuration — copy this file to `.env` and fill it in.
# NEVER commit your real .env (it is git-ignored).
#
#   cp .env.example .env

# ---------------------------------------------------------------------------
# REQUIRED: 32-byte master encryption key, as 64 hexadecimal characters.
# Generate one with:   openssl rand -hex 32
#
# WARNING: if you lose this key, every backup becomes PERMANENTLY unrecoverable.
# Back it up somewhere safe and offline.
# ---------------------------------------------------------------------------
DOCKBACK_ENCRYPTION_KEY=

# Initial admin account. If the password is left blank, a strong one is
# generated and printed in the container logs on first run (shown once).
DOCKBACK_ADMIN_USER=admin
DOCKBACK_ADMIN_PASSWORD=

# Set to true when running behind a trusted TLS reverse proxy that sets
# X-Forwarded-Proto / X-Forwarded-For (enables Secure cookies, HSTS, and correct
# client IPs for the login lockout).
DOCKBACK_TRUST_PROXY=false
# Optional: comma-separated CIDRs/IPs whose X-Forwarded-* headers are trusted.
DOCKBACK_TRUSTED_PROXIES=

# Optional default-deny outbound allow-list — the hosts, domains, or CIDRs the
# app is allowed to reach for offsite storage and notifications.
# Empty = unrestricted.
DOCKBACK_EGRESS_ALLOW=

# Scheduler & concurrency (optional; sensible defaults shown).
DOCKBACK_MAX_CONCURRENT_BACKUPS=3
DOCKBACK_MAX_CONCURRENT_PER_NODE=2
DOCKBACK_SCHEDULE_JITTER=30
# Cap the aggregate offsite upload rate in Mbit/s (0 = unlimited).
DOCKBACK_MAX_UPLOAD_MBPS=0

# Disk-backed scratch where large backups spool their volume archive (NOT RAM).
# Point this at a bigger/faster disk if your backups volume is tight.
DOCKBACK_WORK_DIR=/app/backups/.work

# How long backup verification waits for a freshly-initialized throwaway database
# to accept connections. On slow hardware (e.g. a NAS) a fresh DB can take a few
# minutes to start; raise this if you ever see "throwaway db not ready".
# Seconds; default 300.
DOCKBACK_DB_READY_TIMEOUT=300
