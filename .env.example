# DockBack configuration — copy this file to `.env` and fill it in.
# NEVER commit your real .env (it is git-ignored).
#
#   cp .env.example .env

# ---------------------------------------------------------------------------
# REQUIRED: 32-byte master encryption key, as 64 hexadecimal characters.
# Generate one with:   openssl rand -hex 32
#
# WARNING: if you lose this key, every backup becomes PERMANENTLY unrecoverable.
# Back it up somewhere safe and offline.
#
# ROTATION: to change this key, use Settings -> Encryption -> "Rotate encryption
# key" in the app (it re-wraps existing backups and re-seals node/destination/
# notification/2FA secrets in place). After a successful rotation you MUST update
# DOCKBACK_ENCRYPTION_KEY here to the NEW key before the next restart, and keep the
# OLD key archived until you've verified. Do NOT just change this value on its own
# — that strands every existing backup.
# ---------------------------------------------------------------------------
DOCKBACK_ENCRYPTION_KEY=

# Initial admin account. If the password is left blank, a strong one is
# generated and printed in the container logs on first run (shown once).
DOCKBACK_ADMIN_USER=admin
DOCKBACK_ADMIN_PASSWORD=

# Set to true when running behind a trusted TLS reverse proxy that sets
# X-Forwarded-Proto / X-Forwarded-For (enables Secure cookies, HSTS, and correct
# client IPs for the login lockout).
DOCKBACK_TRUST_PROXY=false
# Optional: comma-separated CIDRs/IPs whose X-Forwarded-* headers are trusted.
DOCKBACK_TRUSTED_PROXIES=

# Optional default-deny outbound allow-list — the hosts, domains, or CIDRs the
# app is allowed to reach for offsite storage and notifications.
# Empty = unrestricted. This is the BOOT DEFAULT: Settings -> Egress allow-list
# lets you view/edit it live (no restart), and an in-app value OVERRIDES this.
DOCKBACK_EGRESS_ALLOW=

# Scheduler & concurrency (optional; sensible defaults shown). The values below
# are the env DEFAULTS; these are ALSO settable in-app under Settings ->
# Performance & tuning (an in-app value overrides the env and applies immediately,
# no restart — a running backup is never interrupted).
DOCKBACK_MAX_CONCURRENT_BACKUPS=3
DOCKBACK_MAX_CONCURRENT_PER_NODE=2
# Also settable in-app (applies to the next scheduled dispatch).
DOCKBACK_SCHEDULE_JITTER=30
# Cap the aggregate offsite upload rate in Mbit/s (0 = unlimited).
# Also settable in-app (applies immediately). Per-destination caps live on each destination.
DOCKBACK_MAX_UPLOAD_MBPS=0

# Store local backups on a bigger disk (e.g. a mounted 2TB SSD).
# By default DockBack keeps local backups in a managed Docker volume. To use a host
# disk instead, set this to a host PATH — docker-compose bind-mounts it at
# /app/backups, so ALL local backups (and the work spool below) land there.
#   1. Make the dir on the SSD:               mkdir -p /mnt/ssd/dockback
#   2. Give it to DockBack's non-root user:   sudo chown -R 65532:65532 /mnt/ssd/dockback
#   3. Set the path here, then:                docker compose up -d
# Leave BLANK to keep using the managed volume. (Changing this later moves WHERE new
# backups are written; copy existing backups over first if you want to keep them.)
DOCKBACK_BACKUPS_DIR_HOST=

# Disk-backed scratch where large backups spool their volume archive (NOT RAM).
# Defaults to a hidden dir on the backups disk above, so pointing DOCKBACK_BACKUPS_DIR_HOST
# at your SSD already puts the work spool on it too. Override only to split them.
DOCKBACK_WORK_DIR=/app/backups/.work

# How long backup verification waits for a freshly-initialized throwaway database
# to accept connections. On slow hardware (e.g. a NAS) a fresh DB can take a few
# minutes to start; raise this if you ever see "throwaway db not ready".
# Seconds; default 300. Also settable in-app under Settings -> Performance &
# tuning (applies immediately, no restart needed).
DOCKBACK_DB_READY_TIMEOUT=300

# The tiny helper image used to copy/measure volume data during a backup. On an
# air-gapped node that can only pull from a private mirror, point this at your
# mirrored Alpine (e.g. registry.internal/alpine:3.20), or every volume backup
# fails pulling the default. Default alpine:3.20. Also settable in-app under
# Settings -> Performance & tuning (an in-app value overrides the env; applies to
# the next backup, no restart needed).
DOCKBACK_SIDECAR_IMAGE=alpine:3.20
